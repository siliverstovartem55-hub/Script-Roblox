local function updateMenuTheme()
    local newColor = getAccentColor()
    for _, el in ipairs(themeElements.fills) do
        if el and el.Parent then
            el.BackgroundColor3 = newColor
        end
    end
    for _, box in ipairs(themeElements.activeBoxes) do
        if box and box.Parent and box.BackgroundColor3 ~= Color3.fromRGB(30, 30, 30) then
            box.BackgroundColor3 = newColor
        end
    end
    for _, item in ipairs(themeElements.buttonsAccent) do
        if item and item.Parent then
            if item:IsA("TextButton") or item:IsA("TextLabel") then
                item.TextColor3 = newColor
            elseif item:IsA("Frame") then
                item.BackgroundColor3 = newColor
            end
        end
    end
end

