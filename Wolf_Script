        info.Text = name .. "\n" .. coords
        info.TextColor3 = Color3.fromRGB(200, 200, 200); info.BackgroundTransparency = 1; info.TextXAlignment = Enum.TextXAlignment.Left; info.Font = Enum.Font.Code; info.TextSize = 10
        info.TextWrapped = true

