        delBtn.Size = UDim2.new(0, 55, 0, 25); delBtn.Position = UDim2.new(0.78, 0, 0.2, 0)
        delBtn.BackgroundColor3 = Color3.fromRGB(30, 30, 30); delBtn.Text = "Delete"
